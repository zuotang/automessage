UPDATE_BASE_URL=https://example.com/automessage

SFTP_HOST=127.0.0.1
SFTP_PORT=22
SFTP_USER=deploy
SFTP_PASSWORD=change_me

# 远程 Nginx 静态目录，和 UPDATE_BASE_URL 对应
SFTP_REMOTE_DIR=/usr/share/nginx/html/automessage

# 使用密钥登录时启用下面两行，并删除 SFTP_PASSWORD
# SFTP_PRIVATE_KEY_PATH=.ssh/id_rsa
# SFTP_PASSPHRASE=
